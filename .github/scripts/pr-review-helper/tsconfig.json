{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "lib": ["ES2023"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": true,
    "noImplicitAny": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node"]
  },
  "include": ["*.ts"]
}
