../app/electron/*.js

# Gitignored copies of frontend/src/ that get populated locally under
# plugins/headlamp-plugin/src/ by the plugin's build script (see
# plugins/headlamp-plugin/src/.gitignore). ESLint does not honor
# .gitignore, so we list these here to (a) avoid lint regressions
# if a future change to the originals removes an inline directive
# but the plugin copy still has the old form, and (b) avoid scanning
# ~700 duplicate .ts/.tsx files (otherwise lint takes ~70% longer).
# Only entries that actually contain .js/.ts/.tsx are listed; the
# gitignored assets/, resources/ and react-app-env.d.ts entries from
# plugins/headlamp-plugin/src/.gitignore have no JS/TS so they don't
# need to be repeated here.
../plugins/headlamp-plugin/src/components/
../plugins/headlamp-plugin/src/helpers/
../plugins/headlamp-plugin/src/i18n/
../plugins/headlamp-plugin/src/lib/
../plugins/headlamp-plugin/src/plugin/
../plugins/headlamp-plugin/src/redux/
../plugins/headlamp-plugin/src/stateless/

# Other gitignored sibling dirs of plugins/headlamp-plugin/ that get
# populated by `npm run build` in the plugin (see plugins/headlamp-plugin/.gitignore):
# - examples/             (bundled copy of plugins/examples/* via scripts/bundle-examples.js)
# - official-plugins/     (fetched from headlamp-k8s/plugins via scripts/fetch-official-plugins.js)
# - .temp-official-plugins/ (intermediate dir used by the same fetch script)
# Without these the frontend lint scan picks up plugin TS/TSX without the
# project's license header etc. and fails.
../plugins/headlamp-plugin/examples/
../plugins/headlamp-plugin/official-plugins/
../plugins/headlamp-plugin/.temp-official-plugins/
