../app/electron/*.js

# Gitignored copies of frontend/src/ that get populated locally under
# plugins/headlamp-plugin/src/ by the plugin's setup scripts (see
# plugins/headlamp-plugin/src/.gitignore). ESLint does not respect
# .gitignore, so we list them here explicitly to keep `npm run lint`
# (and `npm run lint:ci`) clean — the originals in frontend/src/ are
# already linted, and the copies don't carry the inline disable
# directives that the originals do.
../plugins/headlamp-plugin/src/assets/
../plugins/headlamp-plugin/src/components/
../plugins/headlamp-plugin/src/helpers/
../plugins/headlamp-plugin/src/i18n/
../plugins/headlamp-plugin/src/lib/
../plugins/headlamp-plugin/src/plugin/
../plugins/headlamp-plugin/src/redux/
../plugins/headlamp-plugin/src/resources/
../plugins/headlamp-plugin/src/stateless/
../plugins/headlamp-plugin/src/react-app-env.d.ts
