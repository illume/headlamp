{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "outDir": "electron/",
    "noEmit": true,
    "paths": {
      "@langchain/core/dist/tools/index": ["./node_modules/@langchain/core/dist/tools/index"]
    }
  },
  "include": ["electron/**/*"],
  "exclude": []
}
